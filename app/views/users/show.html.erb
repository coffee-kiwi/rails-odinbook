
    <div class="user-page">
        <h2><%= @user.username %></h2>
        <p><%= @user.email %></p>

        <% if @user.avatar.attached? %>
            <%= image_tag @user.avatar,　alt: "#{@user.username}'s Avatar", style: "width: 100px; height: 100px; border-radius: 50%;" %>
        <% elsif @user.avatar_url %>
            <%= image_tag @user.avatar_url, alt: "#{@user.username}'s Avatar", class: "avatar",　style: "width: 100px; height: 100px; border-radius: 50%;" %>
        <% else %>
            <p>No avatar yet</p>
            <!-- Fallback placeholder image if no avatar is uploaded -->
            <%= image_tag ("default-avatar.jpg"),　alt: "#{@user.username}'s Avatar", style: "width: 100px; height: 100px; border-radius: 50%;" %>
        <% end %> 

        <div class="edit-link">
            <%= link_to "Update my details", edit_user_path(current_user) %>
        </div>
        <article class="bio-wrapper">
            <p class="bio-title">Bio:</p>
            <p class="bio"><%=@user.bio%></p>
        </article>
        
        <% @posts.each do |post| %>
            <article class="post">
                <p class="post-title"><%= post.title%></p>
                <p class="post-body"><%= post.body %></p>
            </article>
        <% end %>
    </div>
