<section class="user-wrapper">
    <div class="user-page">
        <h1><%= @user.username %></h1>
        <p><%= @user.email %></p>

        <% if @user.avatar.attached? %>
            <%= image_tag @user.avatar.variant(:thumb),　alt: "#{@user.username}'s Avatar", style: "width: 100px; height: 100px; border-radius: 50%;" %>
        <% elsif @user.avatar_url %>
            <%= image_tag @user.avatar_url, alt: "#{@user.username}'s Avatar", class: "avatar",　style: "width: 100px; height: 100px; border-radius: 50%;" %>
        <% else %>
            <%= image_tag ("default_avatar.jpg"), alt: "#{@user.username}'s Avatar", class: "avatar", style: "width: 100px; height: 100px; border-radius: 50%;" %>
        <% end %> 

        <div class="edit-link">
            <p>
                <%= link_to "Update my details", edit_user_path(current_user) %>
            </p>
        </div>
        <section class="bio-section">
            <h2>Bio:</h2>
            <article class="bio-wrapper">
                <p class="bio"><%=@user.bio%></p>
            </article>
        </section>
        <h2>Posts:</h2>
        <% @posts.each do |post| %>
            <article class="post">
                <p class="post-title"><%= post.title%></p>
                <p class="post-body"><%= post.body %></p>
            </article>
        <% end %>
    </div>
</section>
