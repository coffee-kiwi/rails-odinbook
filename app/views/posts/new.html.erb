<section class="post-wrapper">
    
        <h1>Create a new post</h1>
        <article class="new-post">
        <%= form_with model: @post do |form| %>
        <div class ="form-new-post">
            <div class="post-title">
                <p><%= form.label :title %></p>
                <p><%= form.text_field :title %></p>
            </div>
            <div class="post-title">
                <p><% form.label :body %>Post:</p>
                <p><%= form.text_area :body, size: "30x10" %></p>
            </div>

            <div class="avatar-field post-title">
                <p><%= form.label :avatar %></p>
                <p><%= form.file_field :avatar %></p>
            </div>
            
            <div>
                <button type="submit" class="post-btn">Create Post</button>
            </div>
        </div>
        <% end %>
    </article>
</section>