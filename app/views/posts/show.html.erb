<section class="page-wrapper"> 
    <h1><%= @post.title%></h1>
    <section class="comment-wrapper">  
        
        <div class="author">
            <h2><%= @post.user.username %></h2>
        </div>

        <div class="post-body">
            <%= @post.body%>
        </div>

        <% if @post.avatar.attached? %>
            <%= image_tag @post.avatar, alt: "#{@post.user.username}'s post picture"%>
        <% end %>

        <div class="likes">
            
            <div class="like-buttons">
                <% if @my_like %>
                    <%= button_to "Unlike", post_like_path(@post.id, @my_like.id), method: :delete %>
                <% else %>
                    <%= button_to "Like", post_likes_path(@post), method: :post, params: { post: @post } %>
                <% end %>
            </div>
            <p>Likes <%= @post.likes.count %></p>
        </div>

        <div class="delete-button">
            <%= button_to "Delete Post", post_path(@post), method: :delete, data: { turbo_confirm: "Are you sure?" } %>
        </div>
    </section>
    <h2>Comments for this post:</h2>
    <section class="comments-section">
        
        <div class="displayed-comment">
            <% if @post.comments.exists? %> 
                <% post_comments = @post.comments.to_a %>
                <%= turbo_frame_tag "all_post_comments", src: post_comments_path(@post.id)  %>
                <div id="comments-post-<%= @post.id %>">    
                    <%= render "comments/all_comments", post_comments: post_comments %>
                </div>
            <% else %>
                <div id="comments-post-<%= @post.id %>"</div>
            <% end %>
        </div>

        <div class="new-comment">
            <%= turbo_frame_tag "new_comment_form" do %>
                <%= render "comments/new_comment", post: @post %>
            <% end %>
        </div>
    </section>
</section>